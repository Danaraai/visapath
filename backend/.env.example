ANTHROPIC_API_KEY=your_anthropic_api_key

# TinyFish — web search + browser automation
TINYFISH_API_KEY=your_tinyfish_api_key

# Senso — RAG knowledge base
SENSO_API_KEY=your_senso_api_key

# Nexla MCP server (https://veda-ai.nexla.io/mcp-express/)
# Auth: "Basic <service_key>" — get key from express.dev
NEXLA_API_KEY=your_nexla_service_key

# Vapi — voice AI (intake assistant + outbound slot-found calls)
VAPI_API_KEY=your_vapi_private_api_key
VAPI_PUBLIC_KEY=your_vapi_public_key        # safe to expose in browser
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id

# Redis session storage (optional — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

PORT=3001
